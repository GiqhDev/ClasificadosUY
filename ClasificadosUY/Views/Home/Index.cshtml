@model IEnumerable<ClasificadosUY.Models.Anuncio>



<div class="container mt-4">
  <h2 class="mb-4 text-center">ClasificadosUY</h2>
@*   <div class="col-md-3">
    <a href="@Url.Action("Create", "Anuncio")" class="btn btn-success w-100">Publicar Anuncio</a>
  </div> *@
  <!-- Formulario de búsqueda -->
  <form id="formularioBusqueda" method="get" asp-controller="Home"  asp-action="Index" class="row g-3 mb-4">
    
    <div class="col-md-4">
      <input type="text" name="search" class="form-control" placeholder="Buscar..." value="@Context.Request.Query["search"]" />
    </div>
    <div class="col-md-3">
      <select name="IdCategoria" class="form-select">
        <option value="">Todas las Categorías</option>
        @foreach (var cat in ViewBag.Categorias)
        {
          <option value="@cat.IdCategoria @(Context.Request.Query["IdCategoria"] == cat.IdCategoria.ToString() ? "selected" : "")">@cat.Nombre</option>
        }
      </select>
    </div>
    <div class="col-md-3">
      <select name="IdSubcategoria" class="form-select">
        <option value="">Todas las Subcategorías</option>
        @foreach (var subCat in ViewBag.Subcategorias)
        {
          <option value="@subCat.IdSubcategoria @(Context.Request.Query["IdCategoria"] == subCat.IdSubcategoria.ToString() ? "selected" : "")">@subCat.Nombre</option>
        }
        @* @if (Context.Request.Query["IdCategoria"].Any())
        {
          var catId = int.Parse(Context.Request.Query["IdCategoria"]!);
          var subcats = ((List<ClasificadosUY.Models.Categoria>)ViewBag.Categorias)
          .FirstOrDefault(c => c.IdCategoria == catId)?.Subcategorias;

          if (subcats != null)
          {
            foreach (var sub in subcats)
            {
              <option value="@sub.IdSubcategoria @(Context.Request.Query["IdSubcategoria"] == sub.IdSubcategoria.ToString() ? "selected" : "")">
                @sub.Nombre
              </option>
            }
          }
        } *@
      </select>
    </div>
    <div class="col-md-2">
      <button type="submit" class="btn btn-primary w-100">Filtrar</button>
    </div>
  </form>

  <!-- Anuncios -->
  <div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var anuncio in Model)
    {
      var destacado = anuncio.Destacado != null && anuncio.Destacado.FechaFin > DateTime.Now;
      <div class="col">
        <div class="card h-100 shadow-sm border-@((destacado) ? "warning border-3" : "light")">
          <div class="position-relative">
            <!-- Carrusel de imágenes -->
            <div id="carousel-@anuncio.IdAnuncio" class="carousel slide" data-bs-ride="carousel">
              <div class="carousel-inner">
                @if (!string.IsNullOrEmpty(anuncio.Imagen1))
                {
                  <div class="carousel-item active">
                    <img src="data:image/jpeg;base64,@anuncio.Imagen1" class="d-block w-100 rounded-top" />
                  </div>
                }
                @if (!string.IsNullOrEmpty(anuncio.Imagen2))
                {
                  <div class="carousel-item">
                    <img src="data:image/jpeg;base64,@anuncio.Imagen2" class="d-block w-100 rounded-top" />
                  </div>
                }
                @if (!string.IsNullOrEmpty(anuncio.Imagen3))
                {
                  <div class="carousel-item">
                    <img src="data:image/jpeg;base64,@anuncio.Imagen3" class="d-block w-100 rounded-top" />
                  </div>
                }
                @if (!string.IsNullOrEmpty(anuncio.Imagen4))
                {
                  <div class="carousel-item">
                    <img src="data:image/jpeg;base64,@anuncio.Imagen4" class="d-block w-100 rounded-top" />
                  </div>
                }
                @if (!string.IsNullOrEmpty(anuncio.Imagen5))
                {
                  <div class="carousel-item">
                    <img src="data:image/jpeg;base64,@anuncio.Imagen5" class="d-block w-100 rounded-top" />
                  </div>
                }
              </div>

              <!-- Controles del carrusel -->
              <button class="carousel-control-prev" type="button" data-bs-target="#carousel-@anuncio.IdAnuncio" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
              </button>
              <button class="carousel-control-next" type="button" data-bs-target="#carousel-@anuncio.IdAnuncio" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
              </button>
            </div>            
            @if (destacado)
            {
              <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">Destacado</span>
            }
          </div>
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">@anuncio.Titulo</h5>
            <p class="card-text text-truncate">@anuncio.Descripcion</p>
            <p class="fw-bold text-success">@anuncio.Precio.ToString("C")</p>
            <p class="text-muted small">
              @anuncio.Categoria.Nombre
              @(anuncio.Subcategoria != null ? " / " + anuncio.Subcategoria.Nombre : "")
            </p>
            <a href="@Url.Action("Detalle", "Anuncio", new { id = anuncio.IdAnuncio })" class="btn btn-primary mt-auto">Ver Más</a>
          </div>
        </div>
      </div>
    }
  </div>
</div>
