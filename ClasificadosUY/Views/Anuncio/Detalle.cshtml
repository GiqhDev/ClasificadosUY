@model ClasificadosUY.Models.Anuncio

@{
  ViewData["Title"] = "Detalles del Anuncio";
  Layout = "_Layout";
  var classActivo = Model.Estado == "Activo" ? "text-success" : "text-danger";
}

<div class="container mt-4">
  <div class="card shadow-lg border-0 rounded-3">
    <div class="row g-0">
      <div class="col-md-5">
        <!-- Carrusel de imágenes -->
        <div id="carousel-@Model.IdAnuncio" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            @if (!string.IsNullOrEmpty(Model.Imagen1))
            {
              <div class="carousel-item active">
                <img src="data:image/jpeg;base64,@Model.Imagen1" class="d-block w-100 rounded-top" />
              </div>
            }
            @if (!string.IsNullOrEmpty(Model.Imagen2))
            {
              <div class="carousel-item">
                <img src="data:image/jpeg;base64,@Model.Imagen2" class="d-block w-100 rounded-top" />
              </div>
            }
            @if (!string.IsNullOrEmpty(Model.Imagen3))
            {
              <div class="carousel-item">
                <img src="data:image/jpeg;base64,@Model.Imagen3" class="d-block w-100 rounded-top" />
              </div>
            }
            @if (!string.IsNullOrEmpty(Model.Imagen4))
            {
              <div class="carousel-item">
                <img src="data:image/jpeg;base64,@Model.Imagen4" class="d-block w-100 rounded-top" />
              </div>
            }
            @if (!string.IsNullOrEmpty(Model.Imagen5))
            {
              <div class="carousel-item">
                <img src="data:image/jpeg;base64,@Model.Imagen5" class="d-block w-100 rounded-top" />
              </div>
            }
          </div>

          <!-- Controles del carrusel -->
          <button class="carousel-control-prev" type="button" data-bs-target="#carousel-@Model.IdAnuncio" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#carousel-@Model.IdAnuncio" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
          </button>
        </div>
      </div>
      <div class="col-md-7">
        <div class="card-body">
          <h3 class="card-title">@Model.Titulo</h3>
          <h4 class="text-success">$ @Model.Precio</h4>
          <p class="card-text">@Model.Descripcion</p>
          <hr />
          <p><strong>Categoría:</strong> @Model.Categoria?.Nombre</p>
          <p><strong>Subcategoría:</strong> @Model.Subcategoria?.Nombre</p>
          <p><strong>Publicado por:</strong> @Model.Usuario?.NombreCompleto</p>
          <p><strong>Fecha:</strong> @Model.FechaPublicacion.ToString("dd/MM/yyyy")</p>
          <p><strong>Estado:</strong> <strong class="@classActivo">@Model.Estado</strong></p>
          <a href="javascript:history.back()" class="btn btn-secondary">Volver</a>
        </div>
      </div>
    </div>
  </div>
</div>
